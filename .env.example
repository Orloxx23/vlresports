# Optional: route all vlr.gg requests through a Cloudflare Worker (or any
# compatible proxy) so vlr.gg never sees your server's real IP. Highly
# recommended in production to avoid IP-level rate limiting / bans.
#
# When both vars are set, every request to vlr.gg goes through:
#   ${VLR_PROXY_URL}?u=<encoded vlr.gg URL>
# with the header `X-Proxy-Token: ${VLR_PROXY_TOKEN}`.
#
# When either is empty, the API talks to vlr.gg directly.
VLR_PROXY_URL=https://vlr.orminamadro.workers.dev/
VLR_PROXY_TOKEN=Safeguard-Trickily-Dolly-Purist-Diner-Livable-Cosponsor-Dander-Aspect-Bootlace-Triumph-Passcode-Subtype-Outrank-Gown-Unaltered

# Server port (defaults to 5000)
PORT=5000

# GlitchTip error tracking DSN. When empty, error tracking is disabled.
GLITCHTIP_DSN=https://d5587e7d26334825b1da166963ed0927@glitchtip.hivecode.cloud/3
